{
  "index_name": "xiaomidu",
  "start_urls": [
    "https://suzm.cn/"
  ],
  "sitemap_urls": [
    "https://suzm.cn/sitemap.xml"
  ],
  "stop_urls": [],
  "selectors": {
    "lvl0": {
      "selector": "",
      "global": true,
      "default_value": "文档"
    },
    "lvl1": ".vp-doc h1",
    "lvl2": ".vp-doc h2",
    "lvl3": ".vp-doc h3",
    "lvl4": ".vp-doc h4",
    "lvl5": ".vp-doc h5",
    "text": ".vp-doc p, .vp-doc li, .vp-doc td, .vp-doc code, .vp-doc blockquote"
  },
  "selectors_exclude": [
    ".table-of-contents",
    ".custom-block"
  ],
  "js_render": true,
  "js_wait": 2,
  "use_anchors": true,
  "min_indexed_level": 0,
  "nb_hits": 5000
}